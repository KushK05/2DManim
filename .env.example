# 2DManim environment

# Required for local auth token signing. Use a long random value in real environments.
AUTH_SECRET=replace-with-a-long-random-secret

# Optional model defaults used by the Next.js API routes.
DEFAULT_MODEL=gemini-2.5-flash

# AI providers. API keys are reserved for the production worker/code-generation path.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-medium-latest

# Next.js
PORT=3000
NODE_ENV=development

# Future production architecture from SYSTEM_DESIGN.md
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/2dmanim
REDIS_URL=redis://localhost:6379

# Future S3-compatible video storage
S3_BUCKET=2dmanim-videos
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
CDN_BASE_URL=
