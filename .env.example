# Next.js local auth
AUTH_SECRET=your-local-auth-secret-here

# Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Mistral
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_MODEL=mistral-medium-latest

# Optional explicit default model; if omitted server auto-picks Mistral when key is present, else Gemini
# DEFAULT_MODEL=mistral-medium-latest

# App
PORT=3000
CLIENT_URL=http://localhost:3000
NODE_ENV=development
ENABLE_LOCAL_RENDER=true

# Future production architecture from SYSTEM_DESIGN.md
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/2dmanim
REDIS_URL=redis://localhost:6379
S3_BUCKET=2dmanim-videos
S3_REGION=us-east-1
S3_ENDPOINT=
CDN_BASE_URL=

# Local seeded test user (optional)
TEST_USER_NAME=Test User
TEST_USER_EMAIL=testuser@2dmanim.local
TEST_USER_PASSWORD=TestUser@123
