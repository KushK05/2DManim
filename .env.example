# 2DManim environment

# Required for local auth token signing. Use a long random value in real environments.
AUTH_SECRET=replace-with-a-long-random-secret

# Optional model defaults used by the Next.js API routes.
DEFAULT_MODEL=gemini-2.5-flash

# AI providers. API keys are reserved for the production worker/code-generation path.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-medium-latest

# Worker rendering. Keep disabled until Docker can pull/run the Manim image locally.
ENABLE_DOCKER_RENDER=false
MANIM_DOCKER_IMAGE=manimcommunity/manim:stable
MANIM_RENDER_QUALITY=-ql
MANIM_RENDER_TIMEOUT_MS=120000
MANIM_RENDER_CPUS=1
MANIM_RENDER_MEMORY=1g
MANIM_OUTPUT_DIR=public/generated/videos
MANIM_PUBLIC_BASE_PATH=/generated/videos

# Next.js
PORT=3000
NODE_ENV=development

# Future production architecture from SYSTEM_DESIGN.md
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/2dmanim
REDIS_URL=redis://localhost:6379

# S3-compatible object storage. Works with MinIO, R2, Spaces, B2, Wasabi, AWS S3, etc.
OBJECT_STORAGE_BUCKET=2dmanim-videos
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_ACCESS_KEY_ID=minioadmin
OBJECT_STORAGE_SECRET_ACCESS_KEY=minioadmin
OBJECT_STORAGE_PUBLIC_BASE_URL=http://localhost:9000/2dmanim-videos
CDN_BASE_URL=

# Backward-compatible aliases if you prefer S3_* naming.
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
